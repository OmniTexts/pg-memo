{
  "name": "@omnitexts/pg-memo",
  "version": "0.1.2",
  "license": "MIT",
  "description": "PostgreSQL-based memory search engine for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:check": "tsx scripts/db-check.ts"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.13.0",
    "segmentit": "^2.0.3"
  },
  "optionalDependencies": {
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
