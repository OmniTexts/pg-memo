# --- 基础配置 ---
PG_CONNECTION_STRING=postgresql://postgres:123456@localhost:5432/postgres
PG_SCHEMA=example_vlm

# --- 智谱 AI 配置 (用于向量化和图片识别) ---
ZHIPU_API_KEY=your_zhipu_api_key_here
VISION_MODEL=glm-4v-flash

# --- 媒体存储配置 (本地模式) ---
# MEDIA_ROOT_PATH=./media
# MEDIA_BASE_URL=media/

# --- Cloudflare R2 配置 (在线模式) ---
# R2 存储桶名称
R2_BUCKET_NAME=your-bucket-name
# R2 终结点 (格式: https://<account_id>.r2.cloudflarestorage.com)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2 访问密钥
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# R2 公开访问域名 (用于生成 Markdown 中的图片 URL)
R2_PUBLIC_DOMAIN=https://pub-your-id.r2.dev/

# --- 其他配置 ---
# 向量维度 (智谱 embedding-3 建议使用 2048)
VECTOR_DIMS=2048
